# ── vLLM (LLM inference) ─────────────────────────────────────────
VLLM_BASE_URL=http://127.0.0.1:5000/v1
# LLM_API_KEY=sk-xxxxxxxx

# ── TTS ─────────────────────────────────────────────────────────
TTS_BASE_URL=http://127.0.0.1:5000/v1
# TTS_API_KEY=sk-xxxxxxxx

# ── Whisper (STT) ────────────────────────────────────────────────
# Any value accepted by faster-whisper: shorthand ("tiny", "base",
# "small", "medium", "large-v3") or a HF repo id or local path.
WHISPER_MODEL=small
WHISPER_DEVICE=cuda          # cuda | cpu
WHISPER_COMPUTE=auto         # auto | float16 | int8 | float32 | …
